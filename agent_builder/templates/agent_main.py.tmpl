"""{{agent_name}} — generated by Agent Builder."""

import asyncio
import argparse
import logging
import sys
import time
import traceback
from logging.handlers import RotatingFileHandler
from pathlib import Path

try:
    from dotenv import load_dotenv
except ImportError:  # pragma: no cover - optional dependency
    def load_dotenv(*_args, **_kwargs):
        """Fallback no-op if python-dotenv is not installed."""
        return False

from claude_agent_sdk import (
    ClaudeSDKClient,
    ClaudeAgentOptions,
    AssistantMessage,
    ResultMessage,
    SystemMessage,
    TextBlock,
    ToolUseBlock,
    HookMatcher,
)

AGENT_NAME = "{{agent_name}}"
AGENT_DIR = Path(__file__).parent.resolve()
LOG_PATH = AGENT_DIR / f"{AGENT_NAME}.log"

# --- Logging setup ---
logger = logging.getLogger(f"agent.{AGENT_NAME}")
if not logger.handlers:
    logger.setLevel(logging.DEBUG)
    _fh = RotatingFileHandler(
        LOG_PATH,
        maxBytes=5 * 1024 * 1024,
        backupCount=3,
        encoding="utf-8",
    )
    _fh.setFormatter(logging.Formatter(
        "%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    ))
    logger.addHandler(_fh)
    logger.propagate = False

# --- Identity bootstrap ---

CLAUDE_MD_HEADER = "<!-- AUTO-GENERATED: Do not edit. Modify AGENT.md, SOUL.md, MEMORY.md, or USER.md instead. -->\n\n"

IDENTITY_FILES = [
    ("AGENT.md", "# Agent"),
    ("SOUL.md", "# Soul"),
    ("MEMORY.md", "# Memory"),
    ("USER.md", "# User"),
]


def build_claude_md(verbose: bool = False) -> None:
    """Combine identity files into CLAUDE.md for SDK loading."""
    sections: list[str] = []
    found_files: list[str] = []

    for filename, _header in IDENTITY_FILES:
        filepath = AGENT_DIR / filename
        if filepath.exists():
            content = filepath.read_text(encoding="utf-8")
            sections.append(content)
            if verbose:
                found_files.append(f"{filename} ({len(content)} chars)")
        elif filename == "USER.md":
            if verbose:
                print(f"[build_claude_md] {filename} not found, skipping")
        else:
            raise FileNotFoundError(f"Required identity file not found: {filepath}")

    combined = CLAUDE_MD_HEADER + "\n\n---\n\n".join(sections)
    output_path = AGENT_DIR / "CLAUDE.md"
    output_path.write_text(combined, encoding="utf-8")

    if verbose:
        print(f"[build_claude_md] Found: {', '.join(found_files)}")
        print(f"[build_claude_md] Wrote CLAUDE.md ({len(combined)} chars total)")


# --- Spinner ---

class Spinner:
    FRAMES = ("|", "/", "-", "\\")
    INPUT_PRICE_PER_MT = 15.0
    OUTPUT_PRICE_PER_MT = 75.0

    def __init__(self, label="working"):
        self.label = label
        self.stream = sys.stderr
        self._task = None
        self._paused = False
        self._started_at = None
        self.input_tokens = 0
        self.output_tokens = 0
        self.cost_usd = None

    def add_tokens(self, input_tokens=0, output_tokens=0):
        self.input_tokens += input_tokens
        self.output_tokens += output_tokens

    def set_cost(self, usd):
        self.cost_usd = usd

    def _estimated_cost(self):
        if self.cost_usd is not None:
            return self.cost_usd
        return (
            self.input_tokens * self.INPUT_PRICE_PER_MT / 1_000_000
            + self.output_tokens * self.OUTPUT_PRICE_PER_MT / 1_000_000
        )

    def _render_line(self):
        elapsed = time.monotonic() - (self._started_at or time.monotonic())
        frame = self.FRAMES[int(elapsed * 10) % 4]
        parts = [f"\r  {frame} {self.label} ({elapsed:5.1f}s)"]
        if self.input_tokens or self.output_tokens:
            total = self.input_tokens + self.output_tokens
            parts.append(f" | {total:>6,} tok")
            cost = self._estimated_cost()
            tag = "$" if self.cost_usd is not None else "~$"
            parts.append(f" | {tag}{cost:.4f}")
            if elapsed > 1.0:
                parts.append(f" | {tag}{cost / (elapsed / 60):.2f}/min")
        return "".join(parts)

    async def _spin(self):
        try:
            while True:
                if not self._paused:
                    self.stream.write(self._render_line())
                    self.stream.flush()
                await asyncio.sleep(0.1)
        except asyncio.CancelledError:
            self._clear()
            raise

    def _clear(self):
        self.stream.write("\r" + " " * 120 + "\r")
        self.stream.flush()

    def start(self):
        if self._task is None:
            self._started_at = time.monotonic()
            self._task = asyncio.create_task(self._spin())

    async def stop(self):
        if self._task:
            self._task.cancel()
            try:
                await self._task
            except asyncio.CancelledError:
                pass
            self._task = None
            self._clear()

    class _Pause:
        def __init__(self, s): self.s = s
        def __enter__(self): self.s._paused = True; self.s._clear(); return self
        def __exit__(self, *e): self.s._paused = False

    def paused(self):
        return Spinner._Pause(self)


class _NullCtx:
    def __enter__(self): return self
    def __exit__(self, *e): return None


# --- Tool call formatter ---

def _truncate(s, limit=80):
    s = " ".join(str(s).split())
    return s if len(s) <= limit else s[: limit - 1] + "..."


def format_tool_call(name, tool_input):
    """Render a short one-line summary of a tool call for the user."""
    short_name = name.split("__")[-1] if name.startswith("mcp__") else name
    previews = {
        "Bash": ("command",),
        "Read": ("file_path",),
        "Edit": ("file_path",),
        "Write": ("file_path",),
        "Glob": ("pattern",),
        "Grep": ("pattern",),
        "WebFetch": ("url",),
        "WebSearch": ("query",),
    }
    keys = previews.get(short_name)
    if not keys and name.startswith("mcp__"):
        keys = ("url", "query", "action", "prompt", "path")
    if keys:
        for k in keys:
            v = tool_input.get(k)
            if v:
                return f"  [Tool: {short_name}] {k}={_truncate(v)}"
    for k, v in tool_input.items():
        if isinstance(v, (str, int, float, bool)):
            return f"  [Tool: {short_name}] {k}={_truncate(v)}"
    return f"  [Tool: {short_name}]"


# --- Safety hook ---

_BLOCKED_BASH_PATTERNS = (
    "rm -rf /",
    "rm -rf /*",
    "DROP TABLE",
    "DELETE FROM",
    "> /dev/sda",
    ":(){ :|:& };:",  # fork bomb
)

_SENSITIVE_PATH_MARKERS = (
    ".env",
    ".git/",
    "\\.git\\",
    "pyproject.toml",
    "package.json",
    ".ssh/",
    "\\.ssh\\",
    "id_rsa",
    "id_ed25519",
    "credentials",
)


def _is_sensitive_path(p: str) -> bool:
    lower = p.replace("\\", "/").lower()
    return any(marker.replace("\\", "/").lower() in lower for marker in _SENSITIVE_PATH_MARKERS)


async def safety_hook(input_data, tool_use_id, context):
    """Block destructive bash patterns and writes to sensitive paths."""
    tool_name = input_data.get("tool_name", "")
    tool_input = input_data.get("tool_input", {}) or {}

    if tool_name == "Bash":
        command = tool_input.get("command", "")
        for pattern in _BLOCKED_BASH_PATTERNS:
            if pattern in command:
                return {
                    "hookSpecificOutput": {
                        "hookEventName": "PreToolUse",
                        "permissionDecision": "deny",
                        "permissionDecisionReason": f"Blocked dangerous pattern: {pattern}",
                    }
                }
        return {}

    if tool_name in ("Write", "Edit"):
        path = tool_input.get("file_path", "")
        if path and _is_sensitive_path(path):
            return {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": f"Refusing to modify sensitive path: {path}",
                }
            }
    return {}


# --- Main ---

async def main():
    load_dotenv(AGENT_DIR / ".env")

    parser = argparse.ArgumentParser(description=f"{AGENT_NAME} agent")
    parser.add_argument("--verbose", action="store_true", help="Show debug output")
    args = parser.parse_args()
    verbose = args.verbose

    logger.info("agent startup: cwd=%s verbose=%s", AGENT_DIR, verbose)
    print(f"  Log file: {LOG_PATH}")
    print("  (rotates at 5 MB, keeping 3 backups)")

    build_claude_md(verbose=verbose)

    from tools import tools_server  # noqa: E402

    options = ClaudeAgentOptions(
        setting_sources=["project"],
        cwd=str(AGENT_DIR),
        mcp_servers={"agent_tools": tools_server},
        tools={{tools_list}},
        allowed_tools={{allowed_tools_list}},
        permission_mode="{{permission_mode}}",
        hooks={
            "PreToolUse": [
                HookMatcher(matcher="Bash", hooks=[safety_hook]),
                HookMatcher(matcher="Write", hooks=[safety_hook]),
                HookMatcher(matcher="Edit", hooks=[safety_hook]),
            ],
        },
        max_turns={{max_turns}},
        max_budget_usd={{max_budget_usd}},
    )

    async with ClaudeSDKClient(options=options) as client:
        print(f"\n  {AGENT_NAME} ready. Type 'exit' to quit.\n")

        while True:
            try:
                user_input = await asyncio.to_thread(input, "> ")
            except (EOFError, KeyboardInterrupt):
                logger.info("agent interrupted by user")
                break
            if user_input.strip().lower() in ("exit", "quit"):
                break

            logger.info("user_input: %s", user_input)

            spinner = Spinner("thinking") if not verbose else None
            if spinner:
                spinner.start()
            try:
                await client.query(user_input)
                async for message in client.receive_response():
                    if verbose:
                        print(f"[{message.__class__.__name__}] {message}")

                    if isinstance(message, AssistantMessage):
                        if message.error:
                            logger.error("assistant error: %s", message.error)
                            ctx = spinner.paused() if spinner else _NullCtx()
                            with ctx:
                                print(f"[Error: {message.error}]")
                            continue
                        if spinner and message.usage:
                            spinner.add_tokens(
                                input_tokens=int(message.usage.get("input_tokens", 0) or 0),
                                output_tokens=int(message.usage.get("output_tokens", 0) or 0),
                            )
                        for block in message.content:
                            ctx = spinner.paused() if spinner else _NullCtx()
                            with ctx:
                                if isinstance(block, TextBlock):
                                    print(block.text)
                                elif isinstance(block, ToolUseBlock):
                                    logger.info("tool_use: name=%s input=%s", block.name, block.input)
                                    if verbose:
                                        print(f"  [Tool: {block.name}] Input: {block.input}")
                                    else:
                                        print(format_tool_call(block.name, block.input))
                            if spinner and isinstance(block, ToolUseBlock):
                                spinner.label = f"running {block.name.split('__')[-1]}"
                    elif isinstance(message, ResultMessage):
                        if spinner and message.total_cost_usd:
                            spinner.set_cost(message.total_cost_usd)
                        ctx = spinner.paused() if spinner else _NullCtx()
                        with ctx:
                            if message.is_error:
                                logger.error("result error subtype=%s", message.subtype)
                                print(f"[Failed: {message.subtype}]")
                            if verbose:
                                print(f"  [Session: {message.session_id}]")
                                print(f"  [Turns: {message.num_turns}, Duration: {message.duration_ms}ms]")
                                if message.usage:
                                    print(f"  [Tokens: in={message.usage.get('input_tokens', '?')} out={message.usage.get('output_tokens', '?')}]")
                            if message.total_cost_usd:
                                print(f"  [Cost: ${message.total_cost_usd:.4f}]")
                    elif verbose and isinstance(message, SystemMessage):
                        if message.subtype == "init":
                            print(f"  [Init: {message.data}]")
            except Exception as e:
                logger.error("loop error: %s\n%s", e, traceback.format_exc())
                print(f"[Unexpected error: {e} — see {LOG_PATH.name}]")
            finally:
                if spinner:
                    await spinner.stop()


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except Exception as e:
        logger.critical("fatal: %s\n%s", e, traceback.format_exc())
        print(f"[Fatal: {e} — see {LOG_PATH.name}]")
        raise
