# --- Safety hook ---
#
# NOT A SANDBOX. Substring-matching is best-effort defense-in-depth — it can
# be bypassed by whitespace tricks (`rm  -rf /`), env-var indirection
# (`X=rm; $X -rf /`), piped decoders (`base64 -d | bash`), or paths not in
# the marker list. Run generated agents with `acceptEdits` only in a
# dedicated working directory you can afford to lose.

_BLOCKED_BASH_PATTERNS = (
    "rm -rf /",
    "rm -rf /*",
    "rm -rf ~",
    "DROP TABLE",
    "DELETE FROM",
    "TRUNCATE TABLE",
    "> /dev/sda",
    "mkfs ",
    "dd if=/dev/zero",
    ":(){ :|:& };:",  # fork bomb
    "chmod -R 777 /",
    "chown -R ",
    "curl | sh",
    "curl | bash",
    "wget | sh",
    "wget | bash",
)

_SENSITIVE_PATH_MARKERS = (
    ".env",
    ".git/",
    "\\.git\\",
    "pyproject.toml",
    "package.json",
    ".ssh/",
    "\\.ssh\\",
    "id_rsa",
    "id_ed25519",
    "id_ecdsa",
    "credentials",
    "/etc/shadow",
    "/etc/passwd",
    "/etc/sudoers",
    ".aws/credentials",
    ".aws/config",
    ".kube/config",
    ".docker/config",
    ".netrc",
    ".pgpass",
    "NTUSER.DAT",
    "\\Microsoft\\Credentials",
    "/Keychains/",
)


def _is_sensitive_path(p: str) -> bool:
    lower = p.replace("\\", "/").lower()
    return any(marker.replace("\\", "/").lower() in lower for marker in _SENSITIVE_PATH_MARKERS)


async def safety_hook(input_data, tool_use_id, context):
    """Block destructive bash patterns and writes to sensitive paths."""
    tool_name = input_data.get("tool_name", "")
    tool_input = input_data.get("tool_input", {}) or {}

    if tool_name == "Bash":
        command = tool_input.get("command", "")
        for pattern in _BLOCKED_BASH_PATTERNS:
            if pattern in command:
                return {
                    "hookSpecificOutput": {
                        "hookEventName": "PreToolUse",
                        "permissionDecision": "deny",
                        "permissionDecisionReason": f"Blocked dangerous pattern: {pattern}",
                    }
                }
        return {}

    if tool_name in ("Write", "Edit"):
        path = tool_input.get("file_path", "")
        if path and _is_sensitive_path(path):
            return {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": f"Refusing to modify sensitive path: {path}",
                }
            }
    return {}


# --- Response handling (shared between chat loop and CLI dispatch) ---

async def _drain_responses(client, verbose):
    """Pretty-print + log everything streaming back from one client.query()."""
    spinner = Spinner("thinking") if not verbose else None
    if spinner:
        spinner.start()
    try:
        async for message in client.receive_response():
            if verbose:
                print(f"[{message.__class__.__name__}] {message}")

            if isinstance(message, AssistantMessage):
                if message.error:
                    logger.error("assistant error: %s", message.error)
                    ctx = spinner.paused() if spinner else nullcontext()
                    with ctx:
                        print(f"[Error: {message.error}]")
                    continue
                if spinner and message.usage:
                    spinner.add_tokens(
                        input_tokens=int(message.usage.get("input_tokens", 0) or 0),
                        output_tokens=int(message.usage.get("output_tokens", 0) or 0),
                    )
                for block in message.content:
                    ctx = spinner.paused() if spinner else nullcontext()
                    with ctx:
                        if isinstance(block, TextBlock):
                            print(block.text)
                        elif isinstance(block, ToolUseBlock):
                            logger.info("tool_use: name=%s input=%s", block.name, block.input)
                            if verbose:
                                print(f"  [Tool: {block.name}] Input: {block.input}")
                            else:
                                print(format_tool_call(block.name, block.input))
                    if spinner and isinstance(block, ToolUseBlock):
                        spinner.label = f"running {block.name.split('__')[-1]}"
            elif isinstance(message, ResultMessage):
                if spinner and message.total_cost_usd:
                    spinner.set_cost(message.total_cost_usd)
                ctx = spinner.paused() if spinner else nullcontext()
                with ctx:
                    if message.is_error:
                        logger.error("result error subtype=%s", message.subtype)
                        print(f"[Failed: {message.subtype}]")
                    if verbose:
                        print(f"  [Session: {message.session_id}]")
                        print(f"  [Turns: {message.num_turns}, Duration: {message.duration_ms}ms]")
                        if message.usage:
                            print(f"  [Tokens: in={message.usage.get('input_tokens', '?')} out={message.usage.get('output_tokens', '?')}]")
                    if message.total_cost_usd:
                        print(f"  [Cost: ${message.total_cost_usd:.4f}]")
            elif verbose and isinstance(message, SystemMessage):
                if message.subtype == "init":
                    print(f"  [Init: {message.data}]")
    finally:
        if spinner:
            await spinner.stop()


# --- Main ---

async def main():
    load_dotenv(AGENT_DIR / ".env")

    parser = argparse.ArgumentParser(
        description="{{agent_description}}",
        formatter_class=argparse.RawTextHelpFormatter,
        epilog={{cli_help_epilog}},
    )
    parser.add_argument("-v", "--verbose", action="store_true", help="Show debug output")
{{cli_args_block}}
    args = parser.parse_args()
    verbose = args.verbose

    logger.info("agent startup: cwd=%s verbose=%s", AGENT_DIR, verbose)
    print(f"  Log file: {LOG_PATH}")
    print("  (rotates at 5 MB, keeping 3 backups)")

    build_claude_md(agent_dir=AGENT_DIR, verbose=verbose)

    from tools import tools_server  # noqa: E402

    options = ClaudeAgentOptions(
        setting_sources=["project"],
        cwd=str(AGENT_DIR),
        mcp_servers={
            "agent_tools": tools_server,
            {{recipe_servers_block}}
            {{external_mcp_block}}
        },
        tools={{tools_list}},
        allowed_tools={{allowed_tools_list}},
        permission_mode="{{permission_mode}}",
        hooks={
            "PreToolUse": [
                HookMatcher(matcher="Bash", hooks=[safety_hook]),
                HookMatcher(matcher="Write", hooks=[safety_hook]),
                HookMatcher(matcher="Edit", hooks=[safety_hook]),
            ],
        },
        max_turns={{max_turns}},
        max_budget_usd={{max_budget_usd}},
    )

{{cli_dispatch_block}}
    async with ClaudeSDKClient(options=options) as client:
        print(f"\n  {AGENT_NAME} ready. Type 'exit' to quit.\n")

        while True:
            try:
                user_input = await asyncio.to_thread(input, "> ")
            except (EOFError, KeyboardInterrupt):
                logger.info("agent interrupted by user")
                break
            if user_input.strip().lower() in ("exit", "quit"):
                break

            logger.info("user_input: %s", user_input)

            try:
                await client.query(user_input)
                await _drain_responses(client, verbose)
            except Exception as e:
                logger.error("loop error: %s\n%s", e, traceback.format_exc())
                print(f"[Unexpected error: {e} — see {LOG_PATH.name}]")


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except Exception as e:
        logger.critical("fatal: %s\n%s", e, traceback.format_exc())
        print(f"[Fatal: {e} — see {LOG_PATH.name}]")
        raise
